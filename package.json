{
  "name": "liftwatch",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monitor transit elevator reliability worldwide and rank it on split-flap leaderboards.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "poll": "tsx src/poll.ts",
    "poll:mta": "tsx src/poll.ts mta-nyct",
    "poll:bart": "tsx src/poll.ts bart-bay-area",
    "poll:mbta": "tsx src/poll.ts mbta-boston",
    "poll:wmata": "tsx src/poll.ts wmata-dc",
    "poll:tfl": "tsx src/poll.ts tfl-london",
    "poll:cta": "tsx src/poll.ts cta-chicago",
    "poll:dry": "tsx src/poll.ts mta-nyct --dry-run",
    "poll:bart:dry": "tsx src/poll.ts bart-bay-area --dry-run",
    "poll:mbta:dry": "tsx src/poll.ts mbta-boston --dry-run",
    "poll:wmata:dry": "tsx src/poll.ts wmata-dc --dry-run",
    "poll:tfl:dry": "tsx src/poll.ts tfl-london --dry-run",
    "poll:cta:dry": "tsx src/poll.ts cta-chicago --dry-run",
    "demo:access": "tsx src/checks/accessibility-demo.ts",
    "check:tfl": "tsx src/checks/tfl-redundancy-check.ts",
    "db:status": "tsx src/checks/db-status.ts",
    "site:data": "tsx src/site/build-data.ts",
    "site:serve": "node scripts/serve.mjs",
    "backup": "tsx src/backup/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
